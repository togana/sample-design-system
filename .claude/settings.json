{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "afplay -v 10 /System/Library/Sounds/Ping.aiff"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "afplay -v 10 /System/Library/Sounds/Ping.aiff"
          }
        ]
      }
    ]
  }
}
