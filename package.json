{
  "name": "sample-design-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "panda codegen",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "npm run test:storybook && npm run test:vrt",
    "test:storybook": "vitest run --project=storybook",
    "test:vrt": "npm run build-storybook && npx playwright test",
    "test:vrt:update": "npm run build-storybook && npx playwright test --update-snapshots"
  },
  "dependencies": {
    "@ark-ui/react": "5.34.0",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@pandacss/dev": "1.8.2",
    "@playwright/test": "1.58.2",
    "@storybook/addon-a11y": "10.2.13",
    "@storybook/addon-docs": "10.2.13",
    "@storybook/addon-mcp": "0.3.3",
    "@storybook/addon-themes": "10.2.13",
    "@storybook/addon-vitest": "10.2.13",
    "@storybook/nextjs-vite": "10.2.13",
    "@types/node": "24.10.15",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/browser-playwright": "4.0.18",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "9.39.3",
    "eslint-config-next": "16.1.6",
    "http-server": "14.1.1",
    "playwright": "1.58.2",
    "storybook": "10.2.13",
    "typescript": "5.9.3",
    "typescript-language-server": "5.1.3",
    "vite": "7.3.1",
    "vitest": "4.0.18"
  }
}
